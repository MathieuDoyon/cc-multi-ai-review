{
  "name": "cc-multi-ai-review",
  "version": "0.1.0",
  "description": "Multi-model AI code review engine for the Claude Code /multi-ai-review skill, distributed as a Claude Code plugin.",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MathieuDoyon/cc-multi-ai-review.git"
  },
  "homepage": "https://github.com/MathieuDoyon/cc-multi-ai-review#readme",
  "bugs": {
    "url": "https://github.com/MathieuDoyon/cc-multi-ai-review/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=skills/multi-ai-review/scripts/cli.mjs --banner:js='#!/usr/bin/env node'",
    "sync": "mkdir -p \"$HOME/.claude/skills/multi-ai-review/scripts\" && cp skills/multi-ai-review/scripts/cli.mjs \"$HOME/.claude/skills/multi-ai-review/scripts/cli.mjs\" && cp skills/multi-ai-review/SKILL.md \"$HOME/.claude/skills/multi-ai-review/SKILL.md\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "claude-code",
    "code-review",
    "multi-agent",
    "pi"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
